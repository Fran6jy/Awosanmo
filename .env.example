# ── Awosanmo server configuration ─────────────────────────────
NODE_ENV=production
PORT=8080

# Auth
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# Bootstrap admin (created on first run if no users exist)
ADMIN_EMAIL=admin@awosanmo.local
ADMIN_PASSWORD=changeme123

# Storage
DATA_DIR=./data
DOWNLOAD_DIR=./downloads
MAX_STORAGE_BYTES=95000000000

# Torrent engine (tuned for 1 vCPU / 1GB RAM)
TORRENT_MAX_CONNS=30
TORRENT_DOWNLOAD_LIMIT=0
TORRENT_UPLOAD_LIMIT=51200
TORRENT_MAX_ACTIVE=3

# CORS (comma separated). Empty = same-origin only.
CORS_ORIGINS=
