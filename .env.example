PORT=4000
NODE_ENV=production
DATA_DIR=/var/lib/awosanmo
DB_PATH=/var/lib/awosanmo/awosanmo.sqlite
CORS_ORIGIN=https://your-domain.example
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@awosanmo.local
ADMIN_PASSWORD=replace-with-a-strong-password
MAX_DOWNLOAD_RATE=0
MAX_UPLOAD_RATE=65536
TORRENT_PORT=51413
STREAM_TOKEN_TTL_SECONDS=3600
MEDIA_SCAN_INTERVAL_SECONDS=45
MEDIA_PROBE_TIMEOUT_SECONDS=20
